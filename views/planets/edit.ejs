<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<style>
    body {
        text-align: center;
        }
    form {
        width: 80%;
        margin: 10px auto;
    }
    textarea {
        width: 400px;
        margin-top: 40px;
    }
    button {
        font-size: 15px;
        width: 150px;
        letter-spacing: 3px;
        padding: 3px;
        flex: 1;
    }
    div {
        margin: 20px;
    }
</style>
<body>
    <%- include('../partials/_navbar.ejs') %>

    <h1>Editing <%= planet.name %></h1>

    <form action="/planets/<%- planet._id %>?_method=PUT" method="POST">

    <label for="name">Name:</label>
    <input type="text" name="name" id="name" required value="<%= planet.name %>"/>

    <label for="isHabitable">Habitable</label>
    <input type="checkbox" name="isHabitable" id="isHabitable" <% if (planet.isHabitable) { %>checked<% } %>/>

    <label for="color">Color:</label>
    <input type="text" name="color" id="color" required value="<%= planet.color %>"/>
        <br>
    <label for="image">Image Source:</label>
    <input type="text" name="image" id="image" value="<%= planet.image %>"/><br>

    <label for="description">Description:</label>
    <textarea name="description" id="description" rows="10" columns="100"><%= planet.description %></textarea>
        <br><div></div>
    <button type="submit">EDIT</button>
    </form>
    <form action="/planets/<%= planet._id %>/?_method=DELETE" method="POST">
    <button style="background-color: orangered; border-radius: 5px; border: none;" type="submit">DELETE</button>
    </form>
</body>
</html>